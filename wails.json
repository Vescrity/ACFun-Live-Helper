{
  "$schema": "https://wails.io/schemas/config.v2.json",
  "name": "AcFun Live Helper",
  "outputfilename": "ACFun Live Helper",
  "frontend:dir": ".",
  "frontend:install": "npm install",
  "frontend:build": "npm run build",
  "frontend:dev:watcher": "npm run dev -- --host 127.0.0.1",
  "frontend:dev:serverUrl": "http://127.0.0.1:5173",
  "wailsjsdir": "./wailsjs",
  "debounceMS": 100,
  "devServer": "localhost:34115",
  "info": {
    "companyName": "Hakura",
    "productName": "AcFun Live Helper",
    "productVersion": "1.0.0-rc.3",
    "comments": "AcFun live streaming helper powered by acfunlive-backend"
  },
  "platforms": {
    "windows": {
      "platform": "windows",
      "arch": "amd64",
      "outputFilename": "ACFun Live Helper"
    },
    "linux": {
      "platform": "linux",
      "arch": "amd64",
      "outputFilename": "acfun-live-helper"
    },
    "darwin": {
      "platform": "darwin",
      "arch": "universal",
      "outputFilename": "ACFun Live Helper"
    }
  }
}
